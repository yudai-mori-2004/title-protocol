{
  "name": "@title-protocol/sdk",
  "version": "0.1.2",
  "description": "Title Protocol TypeScript SDK",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/yudai-mori-2004/title-protocol.git",
    "directory": "sdk/ts"
  },
  "homepage": "https://github.com/yudai-mori-2004/title-protocol/tree/main/sdk/ts",
  "author": "Title Protocol Contributors",
  "keywords": [
    "solana",
    "title-protocol",
    "c2pa",
    "tee",
    "cnft",
    "attribution"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/__tests__"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "node --test dist/__tests__/*.test.js"
  },
  "dependencies": {
    "@noble/curves": "^1.8.0",
    "@noble/hashes": "^1.7.0",
    "@solana/web3.js": "^1.95.0",
    "bs58": "^6.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  }
}
