# ===========================================
# Title Protocol Environment Variables
# ===========================================
# Copy to .env and set values. .env is gitignored.

# --- Common ---
SOLANA_RPC_URL=https://api.devnet.solana.com
# A dedicated RPC is recommended (e.g. Helius):
# SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY

# --- Gateway (crates/gateway) ---
GATEWAY_SIGNING_KEY=            # Ed25519 secret key (64-char hex). Random if unset (dev only)
TEE_ENDPOINT=http://localhost:4000
S3_ENDPOINT=                     # Temporary Storage endpoint (S3-compatible API: MinIO, R2, etc.)
S3_PUBLIC_ENDPOINT=              # Client-facing endpoint (defaults to S3_ENDPOINT)
S3_ACCESS_KEY=                   # Access key
S3_SECRET_KEY=                   # Secret key
S3_BUCKET=                       # Bucket name
S3_REGION=                       # Region
# GATEWAY_SOLANA_KEYPAIR=        # Solana wallet for sign-and-mint (Base58, optional)

# --- TEE (crates/tee) ---
TEE_RUNTIME=mock                # "mock" or vendor runtime (see deploy/*/README.md)
PROXY_ADDR=direct               # "direct" | "127.0.0.1:8000" (socat bridge inside TEE VM)
CORE_COLLECTION_MINT=           # Core cNFT Collection Mint address
EXT_COLLECTION_MINT=            # Extension cNFT Collection Mint address
GATEWAY_PUBKEY=                 # Gateway auth Ed25519 public key (Base58, optional)
TRUSTED_EXTENSIONS=phash-v1,hardware-google,c2pa-training-v1,c2pa-license-v1
WASM_DIR=/wasm-modules

# --- Proxy (crates/proxy) ---
# Production: vsock port 8000 (automatic, vendor-aws feature)
# Development: TCP 127.0.0.1:8000 (automatic)

# --- Indexer (indexer/) ---
DATABASE_URL=postgres://title:title_dev@localhost:5432/title_indexer
DAS_ENDPOINTS=https://api.devnet.solana.com
COLLECTION_MINTS=               # Collection Mints to watch (comma-separated)
WEBHOOK_SECRET=                 # Webhook auth secret

# --- DB (docker-compose.production.yml) ---
DB_USER=title
DB_PASSWORD=                    # PostgreSQL password (required for production compose)

# --- Local TempStorage (crates/temp-storage, vendor-local feature) ---
# Used when Gateway is built with --features vendor-local (instead of vendor-aws).
# LOCAL_STORAGE_ENDPOINT=http://localhost:3001    # TEE-facing endpoint (default)
# LOCAL_STORAGE_PUBLIC_ENDPOINT=                  # Client-facing endpoint (defaults to LOCAL_STORAGE_ENDPOINT)
# STORAGE_DIR=/tmp/title-uploads                  # TempStorage server file directory (default)
# STORAGE_PORT=3001                               # TempStorage server port (default)

# --- Vendor-specific deployment ---
# Local:  deploy/local/README.md  (vendor-local, no AWS required)
# AWS:    deploy/aws/README.md    (vendor-aws, production)
